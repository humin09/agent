#!/usr/bin/env python3
"""扫描最近N个月创建的GitLab项目(>1000个)，先并发检查.gitattributes过滤LFS项目，
再only对LFS项目执行clone + 多集群(xa/ly/ks/qd) mc stat检查。

用法:
    python3 ~/agent/gitlab/scan_recent_lfs.py
    python3 ~/agent/gitlab/scan_recent_lfs.py -m 6 -c xa ks -j 24
    python3 ~/agent/gitlab/scan_recent_lfs.py --list-only
    python3 ~/agent/gitlab/scan_recent_lfs.py --max 50          # 只处理前50个LFS项目
"""

import argparse
import base64
import json
import os
import re
import shutil
import subprocess
import sys
import tempfile
from concurrent.futures import ThreadPoolExecutor, as_completed
from datetime import datetime, timedelta, timezone
from urllib.parse import quote

import requests

requests.packages.urllib3.disable_warnings()

GITLAB_URL = "https://gitlab.scnet.cn:9002"
GITLAB_USER = os.environ.get("GITLAB_USER", "root")
GITLAB_PASS = os.environ.get("GITLAB_PASS", "SugonHpc2024_pro")

DEFAULT_CLUSTERS = ["xa", "ly", "ks", "qd"]
BUCKET = "gitlab-lfs-prod"
MC = os.environ.get("MC", "mc")

LFS_EXTENSIONS = {
    ".safetensors", ".bin", ".pt", ".pth", ".ckpt", ".h5", ".onnx", ".pb",
    ".tflite", ".mlmodel", ".model", ".ot", ".ftz", ".gguf",
    ".pkl", ".pickle", ".joblib", ".msgpack", ".npy", ".npz", ".arrow", ".parquet",
    ".7z", ".bz2", ".gz", ".rar", ".tar", ".tgz", ".xz", ".zip", ".zst", ".wasm",
}

LFS_POINTER_RE = re.compile(
    r"^version https://git-lfs\.github\.com/spec/v1\n"
    r"oid sha256:([0-9a-f]{64})\n"
    r"size (\d+)\n$",
    re.MULTILINE,
)


def oid_path(oid: str, alias: str) -> str:
    return f"{alias}/{BUCKET}/{oid[0:2]}/{oid[2:4]}/{oid[4:]}"


def check_oid_multi(oid: str, clusters: list[str]) -> dict[str, bool]:
    out = {}
    for alias in clusters:
        try:
            r = subprocess.run(
                [MC, "stat", oid_path(oid, alias)],
                capture_output=True, timeout=30,
            )
            out[alias] = r.returncode == 0
        except subprocess.TimeoutExpired:
            out[alias] = False
    return out


def has_lfs_ext(filepath: str) -> bool:
    name = filepath.lower()
    if ".tar." in name:
        return True
    _, ext = os.path.splitext(name)
    return ext in LFS_EXTENSIONS


def fmt_size(b: int) -> str:
    if b >= 1024 ** 3:
        return f"{b / 1024 / 1024 / 1024:.1f}GB"
    if b >= 1024 ** 2:
        return f"{b / 1024 / 1024:.0f}MB"
    return f"{b / 1024:.0f}KB"


def ts() -> str:
    return datetime.now().strftime("%H:%M:%S")


def log(msg: str):
    print(f"[{ts()}] {msg}", flush=True)


def fetch_all_projects(months: int, max_page: int = 300) -> list[dict]:
    cutoff = datetime.now(timezone.utc) - timedelta(days=months * 30)
    after_iso = cutoff.isoformat()
    projects = []
    page = 1
    stop = False
    while page <= max_page and not stop:
        try:
            r = requests.get(
                f"{GITLAB_URL}/api/v4/projects",
                params={
                    "created_after": after_iso, "per_page": 100, "page": page,
                    "order_by": "created_at", "sort": "desc",
                    "imported": "false",
                },
                auth=(GITLAB_USER, GITLAB_PASS), verify=False, timeout=30,
            )
            r.raise_for_status()
            batch = r.json()
            if not batch:
                break
            recent_page = []
            for p in batch:
                created_at = p.get("created_at", "")
                if created_at >= after_iso:
                    recent_page.append(p)
            projects.extend(recent_page)
            all_old = all(p.get("created_at", "") < after_iso for p in batch)
            if all_old:
                log(f"  page={page} 全部超出时间范围，停止翻页")
                stop = True
            if page % 10 == 0 or len(batch) < 100 or stop:
                log(f"  已获取 {len(projects)}/{page * 100} 个项目 (page={page})")
            if len(batch) < 100:
                break
            page += 1
        except Exception as e:
            log(f"  page={page} 出错: {e}")
            break
    return projects


def check_gitattributes(project: dict) -> bool:
    """返回 True 表示该项目 .gitattributes 包含 filter=lfs"""
    pid = project["id"]
    ref = project.get("default_branch") or "main"
    try:
        r = requests.get(
            f"{GITLAB_URL}/api/v4/projects/{pid}/repository/files/.gitattributes",
            params={"ref": ref},
            auth=(GITLAB_USER, GITLAB_PASS), verify=False, timeout=10,
        )
        if r.status_code != 200:
            return False
        data = r.json()
        content = base64.b64decode(data.get("content", "")).decode("utf-8", errors="ignore")
        return "filter=lfs" in content
    except Exception:
        return False


def clone_shallow(repo_url: str, name: str) -> str:
    tmpdir = tempfile.mkdtemp(prefix=f"lfs_scan_{name}_")
    clone_url = repo_url.replace(
        "https://",
        f"https://{quote(GITLAB_USER)}:{quote(GITLAB_PASS)}@",
    )
    if not clone_url.endswith(".git"):
        clone_url += ".git"
    env = os.environ.copy()
    env["GIT_LFS_SKIP_SMUDGE"] = "1"
    env["GIT_TERMINAL_PROMPT"] = "0"
    try:
        subprocess.run(
            ["git", "clone", "--depth", "1", clone_url, os.path.join(tmpdir, "repo")],
            capture_output=True, timeout=300, env=env,
        )
    except subprocess.TimeoutExpired:
        pass
    return tmpdir


def extract_pointers(clone_dir: str) -> list[tuple[str, str, int]]:
    pointers = []
    repo_dir = os.path.join(clone_dir, "repo")
    if not os.path.isdir(repo_dir):
        return pointers
    for root, _, files in os.walk(repo_dir):
        for fname in files:
            fpath = os.path.join(root, fname)
            rel = os.path.relpath(fpath, repo_dir)
            if rel.startswith(".git"):
                continue
            if not has_lfs_ext(rel):
                continue
            try:
                with open(fpath, "r", errors="ignore") as f:
                    content = f.read(512)
                m = LFS_POINTER_RE.match(content)
                if m:
                    pointers.append((rel, m.group(1), int(m.group(2))))
            except Exception:
                continue
    return pointers


def main():
    parser = argparse.ArgumentParser(
        description="扫描最近N个月GitLab项目 + 多集群LFS完备性检查",
    )
    parser.add_argument("-m", "--months", type=int, default=3,
                        help="扫描最近N个月 (默认3)")
    parser.add_argument("-c", "--clusters", nargs="+", default=DEFAULT_CLUSTERS,
                        help="MinIO集群别名 (默认 xa ly ks qd)")
    parser.add_argument("-j", "--jobs", type=int, default=16,
                        help="并发数 (默认16)")
    parser.add_argument("--list-only", action="store_true",
                        help="仅列出LFS项目，不检查mc stat")
    parser.add_argument("--max", type=int, default=0,
                        help="限制最多处理的LFS项目数 (0=全部，建议先用--list-only观察)")
    parser.add_argument("--max-page", type=int, default=250,
                        help="API最大翻页数 (默认250=25000项目)")
    parser.add_argument("-o", "--output", default="/tmp/scan_recent_lfs_report.md",
                        help="输出报告路径")
    args = parser.parse_args()

    # ── 1. 获取项目列表 ─────────────────────────────────────────────
    log(f"=== 获取最近 {args.months} 个月创建的 GitLab 项目 (max_page={args.max_page}) ===")
    projects = fetch_all_projects(args.months, max_page=args.max_page)
    log(f"总计 {len(projects)} 个项目")

    # ── 2. 并发过滤：检查 .gitattributes ─────────────────────────────
    log(f"并发检查 .gitattributes (jobs={args.jobs})...")
    lfs_candidates: list[dict] = []

    with ThreadPoolExecutor(max_workers=args.jobs) as pool:
        future_to_proj = {pool.submit(check_gitattributes, p): p for p in projects}
        done = 0
        for fut in as_completed(future_to_proj):
            done += 1
            proj = future_to_proj[fut]
            try:
                if fut.result():
                    lfs_candidates.append(proj)
            except Exception:
                pass
            if done % 200 == 0 or done == len(projects):
                log(f"  检查进度 {done}/{len(projects)}  LFS候选={len(lfs_candidates)}")

    log(f"LFS 项目: {len(lfs_candidates)}/{len(projects)}")

    if args.max and len(lfs_candidates) > args.max:
        log(f"限制前 {args.max} 个LFS项目 (原 {len(lfs_candidates)})")
        lfs_candidates = lfs_candidates[:args.max]

    if args.list_only or not lfs_candidates:
        if args.list_only:
            log("列出模式，跳过mc检查")
        for idx, p in enumerate(lfs_candidates, 1):
            ns = p.get("namespace", {}).get("full_path", "")
            created = p.get("created_at", "")[:10]
            print(f"  {idx:>4}  {created}  {ns}/{p['name']}")
        return

    # ── 3. Clone + 多集群 mc stat ──────────────────────────────────
    report_lines = [
        f"# GitLab LFS 完备性报告",
        f"",
        f"- 扫描时间: {datetime.now():%Y-%m-%d %H:%M:%S}",
        f"- 时间范围: 最近 {args.months} 个月",
        f"- 集群: {', '.join(args.clusters)}",
        f"- 总项目数: {len(projects)}",
        f"- LFS 项目数: {len(lfs_candidates)}",
        f"- 检查项目数: {len(lfs_candidates)}",
        f"",
        f"## 项目汇总",
        f"",
        "| # | 项目 | 创建时间 | LFS数 | " +
        " | ".join(args.clusters) + " | 状态 |",
        "|" + "---|" * (5 + len(args.clusters)) + "",
    ]

    summary = {
        "scan_time": datetime.now().isoformat(),
        "months": args.months,
        "clusters": args.clusters,
        "total_projects": len(projects),
        "lfs_projects": len(lfs_candidates),
        "results": [],
    }

    incomplete_count = 0
    total_missing_oids = 0

    for idx, p in enumerate(lfs_candidates, 1):
        ns = p.get("namespace", {}).get("full_path", "")
        name = p["name"]
        full_name = f"{ns}/{name}"
        created = p.get("created_at", "")[:10]
        http_url = p.get("http_url_to_repo", "")

        log(f"[{idx}/{len(lfs_candidates)}] {full_name}")

        try:
            tmpdir = clone_shallow(http_url, name)
            pointers = extract_pointers(tmpdir)
            shutil.rmtree(tmpdir, ignore_errors=True)
        except Exception as e:
            log(f"  clone 失败: {e}")
            pointers = []

        if not pointers:
            log(f"  无 LFS 指针")
            cols = " | ".join(["—" if False else "0"] for _ in args.clusters)
            row = f"| {idx} | {full_name} | {created} | 0 | " + \
                  " | ".join("—" for _ in args.clusters) + " | 无LFS对象 |"
            report_lines.append(row)
            summary["results"].append({
                "project": full_name, "created": created,
                "lfs_count": 0, "status": "无LFS对象",
            })
            continue

        log(f"  {len(pointers)} 个对象 x {len(args.clusters)} 集群...")

        cluster_stats = {c: {"exist": 0, "miss": 0, "total": 0} for c in args.clusters}
        missing_items = []

        with ThreadPoolExecutor(max_workers=args.jobs) as pool:
            futures = {
                pool.submit(check_oid_multi, oid, args.clusters): (rel, oid, size)
                for rel, oid, size in pointers
            }
            results_map = {}
            for fut in as_completed(futures):
                rel, oid, size = futures[fut]
                try:
                    results_map[(rel, oid, size)] = fut.result()
                except Exception:
                    results_map[(rel, oid, size)] = {c: False for c in args.clusters}

        for rel, oid, size in pointers:
            exists_map = results_map[(rel, oid, size)]
            for c in args.clusters:
                cluster_stats[c]["total"] += 1
                if exists_map.get(c):
                    cluster_stats[c]["exist"] += 1
                else:
                    cluster_stats[c]["miss"] += 1

            miss_clusters = [c for c in args.clusters if not exists_map.get(c)]
            if miss_clusters:
                missing_items.append({
                    "oid": oid, "file": rel, "size": fmt_size(size),
                    "missing_in": miss_clusters,
                })

        all_ok = all(cluster_stats[c]["miss"] == 0 for c in args.clusters)
        status = "COMPLETE" if all_ok else "INCOMPLETE"

        def cell(c: str) -> str:
            s = cluster_stats[c]
            if s["miss"] == 0:
                return "✅"
            return f"❌{s['miss']}"

        cells = " | ".join(cell(c) for c in args.clusters)
        row = f"| {idx} | {full_name} | {created} | {len(pointers)} | {cells} | {status} |"
        report_lines.append(row)

        log(f"  → {status}" +
            " " + " ".join(f"{c}:{cluster_stats[c]['miss']}miss" for c in args.clusters))

        if not all_ok:
            incomplete_count += 1
            total_missing_oids += len(missing_items)

        if missing_items:
            report_lines.append("")
            report_lines.append(f"<details><summary>{full_name} 缺失明细 ({len(missing_items)})</summary>")
            report_lines.append("")
            report_lines.append("| OID | 文件 | 大小 | 缺失集群 |")
            report_lines.append("|-----|------|------|---------|")
            for d in missing_items[:20]:
                report_lines.append(
                    f"| `{d['oid'][:16]}...` | {d['file']} | {d['size']} | {', '.join(d['missing_in'])} |"
                )
            if len(missing_items) > 20:
                report_lines.append(f"| ... | 还有 {len(missing_items)-20} 个 | - | - |")
            report_lines.append("")
            report_lines.append("</details>")

        summary["results"].append({
            "project": full_name, "created": created,
            "lfs_count": len(pointers), "status": status,
            "cluster_stats": {c: cluster_stats[c] for c in args.clusters},
            "missing_count": len(missing_items),
        })

    # ── 汇总 ─────────────────────────────────────────────────────
    report_lines.extend([
        "",
        "## 统计",
        "",
        f"- 检查 LFS 项目: {len(lfs_candidates)}",
        f"- 完整项目: {len(lfs_candidates) - incomplete_count}",
        f"- 不完整项目: {incomplete_count}",
        f"- 缺失对象总数: {total_missing_oids}",
    ])

    with open(args.output, "w") as f:
        f.write("\n".join(report_lines) + "\n")

    json_output = args.output.replace(".md", ".json")
    with open(json_output, "w") as f:
        json.dump(summary, f, indent=2, ensure_ascii=False)

    log("")
    log(f"✅ 完成")
    log(f"   报告: {args.output}")
    log(f"   JSON: {json_output}")
    log(f"   不完整: {incomplete_count}/{len(lfs_candidates)}")


if __name__ == "__main__":
    main()
